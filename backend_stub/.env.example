# ShiftSwift HR — environment template (copy to backend_stub/.env)
# Production domain: shiftswifthr.co.uk

APP_ENV=development
APP_DOMAIN=shiftswifthr.co.uk
MARKETING_URL=https://www.shiftswifthr.co.uk
APP_URL=https://app.shiftswifthr.co.uk
API_URL=https://api.shiftswifthr.co.uk
LOCAL_API_URL=http://localhost:3000
LOCAL_APP_URL=http://localhost:5173

DATABASE_URL=postgresql://USER@localhost:5432/shiftswift_hr
JWT_SECRET=local-dev-jwt-secret-change-in-production
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
MASTER_CUSTOMER_ID=999
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://app.shiftswifthr.co.uk,https://www.shiftswifthr.co.uk
TRUSTED_HOSTS=localhost,127.0.0.1,api.shiftswifthr.co.uk,app.shiftswifthr.co.uk,www.shiftswifthr.co.uk
FORCE_HTTPS=0
USE_DB=1
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=900
MAX_UPLOAD_BYTES=10485760

# Brand emails (@shiftswifthr.co.uk)
# EMAIL_SUPPORT = Reply-To for ShiftSwift platform mail (welcome, employee, password reset)
EMAIL_HELLO=hello@shiftswifthr.co.uk
EMAIL_SUPPORT=support@shiftswifthr.co.uk
EMAIL_LEGAL=legal@shiftswifthr.co.uk
EMAIL_NOREPLY=noreply@shiftswifthr.co.uk
EMAIL_COMPLIANCE=compliance@shiftswifthr.co.uk
EMAIL_ADMIN=admin@shiftswifthr.co.uk
EMAIL_HR=hr@shiftswifthr.co.uk
PROVIDER_LEGAL_NAME="Datasoftware Analytics Ltd"
PROVIDER_COMPANY_NUMBER="14568900"
PROVIDER_EMAIL=legal@shiftswifthr.co.uk
PROVIDER_ADDRESS="235 Charlbury Road, Nottingham, NG8 1NF"

# Grievance module — 64 hex characters (32 bytes). Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Home Office compliance
RTW_STORAGE_DIR=uploads/rtw_immutable
UK_RTW_CHECKLIST_URL=https://www.gov.uk/government/publications/right-to-work-checklist
SPONSOR_ABSENCE_ALERT_DAY=9
SMS_REPORTING_WINDOW_DAYS=10

# Optional: digital RTW via certified IDSP (TrustID, Yoti, Credas)
IDSP_API_KEY=
IDSP_API_URL=

# Notification delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@shiftswifthr.co.uk
SMTP_FROM_NAME=ShiftSwift HR
# Reply-To display name for support@ (tenant business mail uses tenant billing/signatory email)
SMTP_REPLY_NAME=ShiftSwift HR Support
EMAIL_LOGO_URL=https://app.shiftswifthr.co.uk/assets/shiftswift-hr-logo.png
SMTP_TO=
SMTP_USE_TLS=1
COMPLIANCE_ALERT_EMAIL=compliance@shiftswifthr.co.uk

# B2B trial & upgrade (14-day default)
BILLING_DD_GRACE_DAYS=7
BILLING_TRIAL_DAYS=14
BILLING_UPGRADE_URL=https://app.shiftswifthr.co.uk/admin.html#payroll
BILLING_UPGRADE_SUCCESS_URL=https://app.shiftswifthr.co.uk/admin.html?upgraded=1#payroll
BILLING_UPGRADE_CANCEL_URL=https://app.shiftswifthr.co.uk/admin.html#overview
BILLING_MANDATE_SUCCESS_URL=https://app.shiftswifthr.co.uk/admin.html?mandate=confirmed#payroll
BILLING_MANDATE_CANCEL_URL=https://app.shiftswifthr.co.uk/admin.html#payroll
BILLING_SETUP_SUCCESS_URL=http://localhost:5173/signup-success.html
BILLING_SETUP_CANCEL_URL=http://localhost:5173/signup.html

# Local dev login (seeded by scripts/seed_app_users.py — not used in production)
DEV_MASTER_USERNAME=admin@shiftswifthr.co.uk
DEV_MASTER_PASSWORD=ShiftswiftHR-Platform-2026
DEV_TENANT_USERNAME=hr@shiftswifthr.co.uk
DEV_TENANT_PASSWORD=ShiftswiftHR-Tenant-2026

# AI document assistant — Google Gemini 2.0 Flash (recommended, low cost)
AI_ENABLED=1
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_MAX_OUTPUT_TOKENS=4096

# Stripe B2B billing (optional until go-live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TAX_ENABLED=1
STRIPE_CURRENCY=gbp
STRIPE_PAYMENT_METHODS=bacs_debit,card
STRIPE_PRICE_SITE_STARTER_MONTHLY=
STRIPE_PRICE_SITE_MEDIUM_MONTHLY=
STRIPE_PRICE_SITE_GROWTH_MONTHLY=
STRIPE_PRICE_SITE_STARTER_ANNUAL=
STRIPE_PRICE_SITE_MEDIUM_ANNUAL=
STRIPE_PRICE_SITE_GROWTH_ANNUAL=
STRIPE_PRICE_PAYROLL_STARTER_MONTHLY=
STRIPE_PRICE_PAYROLL_STANDARD_MONTHLY=
STRIPE_PRICE_PAYROLL_GROWTH_MONTHLY=
STRIPE_PRICE_PAYROLL_SCALE_MONTHLY=
